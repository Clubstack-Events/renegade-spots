---
import '../styles/global.css';

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="Renegade spots — Brooklyn industrial and waterfront locations." />
    <meta name="theme-color" content="#0d1117" />
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
    <title>{title}</title>
  </head>
  <body>
    <!-- Bloom SVG Filters -->
    <svg xmlns="http://www.w3.org/2000/svg" style="position:absolute;width:0;height:0;overflow:hidden" aria-hidden="true">
      <defs>
        <filter id="bloom-filter" x="-100%" y="-100%" width="300%" height="300%">
          <feColorMatrix type="matrix" values="2 0 0 0 -0.5  0 2 0 0 -0.5  0 0 2 0 -0.5  0 0 0 1 0" result="bright" />
          <feGaussianBlur in="bright" stdDeviation="4.5" result="glow" />
          <feBlend in="SourceGraphic" in2="glow" mode="screen" />
        </filter>
        <filter id="bloom-filter-subtle" x="-100%" y="-100%" width="300%" height="300%">
          <feColorMatrix type="matrix" values="2 0 0 0 -0.5  0 2 0 0 -0.5  0 0 2 0 -0.5  0 0 0 1 0" result="bright" />
          <feGaussianBlur in="bright" stdDeviation="2.25" result="glow" />
          <feBlend in="SourceGraphic" in2="glow" mode="screen" />
        </filter>
      </defs>
    </svg>
    <slot />
  </body>
</html>
