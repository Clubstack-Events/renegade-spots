---
import hero from '../data/hero.json';
---

<section class="hero">
  <div class="container">
    <div class="hero__meta">
      {hero.tags.map((tag) => (
        <span class="hero__tag">{tag}</span>
      ))}
    </div>
    <div class="hero__title">
      <h1>Renegade Spots</h1>
    </div>
    <div class="hero__details">
      {hero.details.map((d) => (
        <div class="hero__detail">
          <span class="hero__detail-label">{d.label}</span>
          <span class="hero__detail-value">{d.value}</span>
        </div>
      ))}
    </div>
    <p class="hero__sub">{hero.subtitle}</p>
  </div>
  <div class="hero__gradient" aria-hidden="true"></div>
</section>

<style>
  .hero {
    position: relative;
    padding: 10rem 0 var(--space-2xl);
    overflow: hidden;
    border-bottom: 1px solid var(--border);
  }

  .hero__gradient {
    position: absolute;
    top: -40%;
    right: -20%;
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, oklch(75% .15 195 / .08) 0%, transparent 70%);
    pointer-events: none;
  }

  .hero__meta {
    display: flex;
    gap: var(--space-sm);
    margin-bottom: var(--space-lg);
  }

  .hero__tag {
    font-family: var(--font-mono);
    font-size: .65rem;
    font-weight: 500;
    letter-spacing: .1em;
    text-transform: uppercase;
    color: var(--accent);
    padding: 4px 10px;
    border: 1px solid oklch(75% .15 195 / .3);
    border-radius: 100px;
  }

  .hero__title {
    margin-bottom: var(--space-xl);
  }

  .hero__title h1 {
    font-size: clamp(2.5rem, 7vw, 4rem);
    font-weight: 700;
    letter-spacing: -.03em;
    color: var(--text);
  }

  .hero__details {
    display: grid;
    grid-template-columns: repeat(4, auto);
    gap: var(--space-xl);
    margin-bottom: var(--space-xl);
  }

  .hero__detail {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .hero__detail-label {
    font-family: var(--font-mono);
    font-size: .6rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: .12em;
    color: var(--text-dim);
  }

  .hero__detail-value {
    font-size: .95rem;
    font-weight: 500;
    color: var(--text);
  }

  .hero__sub {
    max-width: 540px;
    font-size: .95rem;
    line-height: 1.6;
  }

  @media (max-width: 768px) {
    .hero { padding-top: 7rem; }
    .hero__details {
      grid-template-columns: repeat(2, 1fr);
      gap: var(--space-md);
    }
  }
</style>
