---
import hero from '../data/hero.json';
---

<section class="hero">
  <div class="container">
    <div class="hero__lockup">
      <img src={`${import.meta.env.BASE_URL}brand/kntxt-full.png`} alt="KNTXT" class="hero__wordmark hero__wordmark--kntxt" />
      <span class="hero__x">&times;</span>
      <img src={`${import.meta.env.BASE_URL}brand/wordmark.svg`} alt="Clubstack" class="hero__wordmark hero__wordmark--cs" />
    </div>
    <h1 class="hero__title">Renegade Spots</h1>
    <div class="hero__details">
      {hero.details.map((d) => (
        <div class="hero__detail">
          <span class="hero__detail-label">{d.label}</span>
          <span class="hero__detail-value">{d.value}</span>
        </div>
      ))}
    </div>
    <p class="hero__sub">{hero.subtitle}</p>
  </div>
  <div class="hero__gradient" aria-hidden="true"></div>
</section>

<style>
  .hero {
    position: relative;
    padding: 8rem 0 var(--space-2xl);
    overflow: hidden;
    border-bottom: 1px solid var(--border);
  }

  .hero__gradient {
    position: absolute;
    top: -40%;
    right: -20%;
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, oklch(75% .15 195 / .08) 0%, transparent 70%);
    pointer-events: none;
  }

  .hero__lockup {
    display: flex;
    align-items: center;
    gap: clamp(.75rem, 2vw, 1.5rem);
    margin-bottom: var(--space-lg);
    opacity: .7;
  }

  .hero__wordmark {
    display: block;
    height: clamp(28px, 5vw, 44px);
    width: auto;
  }

  .hero__wordmark--kntxt {
    height: clamp(100px, 22vw, 200px);
  }

  .hero__wordmark--cs {
    filter: brightness(0) invert(1);
    opacity: .9;
  }

  .hero__x {
    color: var(--text-dim);
    font-size: clamp(1rem, 2vw, 1.6rem);
    font-weight: 300;
    line-height: 1;
    flex-shrink: 0;
  }

  .hero__title {
    font-size: clamp(2rem, 7vw, 3.5rem);
    font-weight: 700;
    letter-spacing: -.03em;
    color: var(--text);
    margin-bottom: var(--space-xl);
  }

  .hero__details {
    display: grid;
    grid-template-columns: repeat(4, auto);
    gap: var(--space-xl);
    margin-bottom: var(--space-xl);
  }

  .hero__detail {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .hero__detail-label {
    font-family: var(--font-mono);
    font-size: .6rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: .12em;
    color: var(--text-dim);
  }

  .hero__detail-value {
    font-size: .95rem;
    font-weight: 500;
    color: var(--text);
  }

  .hero__sub {
    max-width: 540px;
    font-size: .95rem;
    line-height: 1.6;
  }

  @media (max-width: 768px) {
    .hero {
      padding-top: 6rem;
    }
    .hero__lockup {
      gap: .5rem;
    }
    .hero__details {
      grid-template-columns: repeat(2, 1fr);
      gap: var(--space-md);
    }
  }
</style>
