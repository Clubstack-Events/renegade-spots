---
---

<nav class="nav">
  <div class="nav__inner container">
    <a href="#" class="nav__logo">
      <img src={`${import.meta.env.BASE_URL}brand/kntxt.png`} alt="KNTXT" class="nav__icon nav__icon--kntxt" />
      <img src={`${import.meta.env.BASE_URL}brand/icon.svg`} alt="Clubstack" class="nav__icon nav__icon--cs" />
    </a>
  </div>
</nav>

<style>
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: oklch(8% .015 240 / .85);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid oklch(18% .02 240);
  }

  .nav__inner {
    display: flex;
    align-items: center;
    height: 56px;
  }

  .nav__logo {
    display: flex;
    align-items: center;
    gap: .15rem;
    opacity: .75;
  }

  .nav__logo:hover { opacity: 1; }

  .nav__icon {
    height: 18px;
    width: auto;
  }

  .nav__icon--cs {
    filter: brightness(0) invert(1);
    height: 18px;
  }
</style>
