---
const links = [
  { href: '#spots', label: 'Spots' },
];
---

<nav class="nav">
  <div class="nav__inner container">
    <a href="#" class="nav__logo">
      <img src={`${import.meta.env.BASE_URL}brand/icon.svg`} alt="Clubstack" class="nav__icon" />
    </a>
    <ul class="nav__links">
      {links.map(({ href, label }) => (
        <li><a href={href}>{label}</a></li>
      ))}
    </ul>
  </div>
</nav>

<style>
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: oklch(8% .015 240 / .85);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid oklch(18% .02 240);
  }

  .nav__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 56px;
  }

  .nav__logo {
    display: flex;
    align-items: center;
    gap: .35rem;
    opacity: .75;
  }

  .nav__logo:hover { opacity: 1; }

  .nav__icon {
    height: 18px;
    width: auto;
    filter: brightness(0) invert(1);
  }

  .nav__links {
    display: flex;
    list-style: none;
    gap: var(--space-lg);
  }

  .nav__links a {
    font-family: var(--font-mono);
    font-size: .7rem;
    font-weight: 500;
    letter-spacing: .1em;
    text-transform: uppercase;
    color: var(--text-muted);
    text-decoration: none;
    transition: color var(--duration) var(--ease);
  }

  .nav__links a:hover { color: var(--accent); }

  @media (max-width: 600px) {
    .nav__links { gap: var(--space-md); }
    .nav__links a { font-size: .6rem; }
  }
</style>
