---

---

<footer class="footer">
  <div class="container footer__inner">
    <div class="footer__brand">
      <span class="footer__produced">Produced by</span>
      <a href="https://clubstack.studio" target="_blank" rel="noopener noreferrer" class="footer__logo-link">
        <img src={`${import.meta.env.BASE_URL}brand/icon.svg`} alt="Clubstack" class="footer__logo" width="24" height="24" />
        <span class="footer__cs-name">Clubstack</span>
      </a>
    </div>
    <div class="footer__info">
      <span>Brooklyn, NY</span>
    </div>
  </div>
</footer>

<style>
  .footer {
    padding: var(--space-xl) 0;
    border-top: 1px solid var(--border);
  }

  .footer__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .footer__brand {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
  }

  .footer__produced {
    font-family: var(--font-mono);
    font-size: .6rem;
    text-transform: uppercase;
    letter-spacing: .1em;
    color: var(--text-dim);
  }

  .footer__logo-link {
    display: inline-flex;
    align-items: center;
    gap: .4rem;
    color: var(--text-muted);
    text-decoration: none;
    transition: color var(--duration) var(--ease);
  }

  .footer__logo-link:hover {
    color: var(--text);
    opacity: 1;
  }

  .footer__logo {
    flex-shrink: 0;
    filter: brightness(0) invert(1);
    opacity: .7;
  }

  .footer__cs-name {
    font-family: var(--font-display);
    font-size: .85rem;
    font-weight: 600;
    letter-spacing: .04em;
  }

  .footer__info {
    font-family: var(--font-mono);
    font-size: .65rem;
    color: var(--text-dim);
    letter-spacing: .04em;
  }

  @media (max-width: 600px) {
    .footer__inner {
      flex-direction: column;
      gap: var(--space-md);
      text-align: center;
    }
  }
</style>
