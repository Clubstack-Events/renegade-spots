---

---

<footer class="footer">
  <div class="container footer__inner">
    <div class="footer__brand">
      <span class="footer__produced">Produced by</span>
      <div class="footer__logos">
        <img src={`${import.meta.env.BASE_URL}brand/kntxt.png`} alt="KNTXT" class="footer__logo footer__logo--kntxt" />
        <span class="footer__x">&times;</span>
        <a href="https://clubstack.studio" target="_blank" rel="noopener noreferrer" class="footer__cs-link">
          <img src={`${import.meta.env.BASE_URL}brand/icon.svg`} alt="Clubstack" class="footer__logo footer__logo--cs" />
          <span class="footer__cs-name">Clubstack</span>
        </a>
      </div>
    </div>
    <div class="footer__info">
      <span>Brooklyn, NY</span>
    </div>
  </div>
</footer>

<style>
  .footer {
    padding: var(--space-xl) 0;
    border-top: 1px solid var(--border);
  }

  .footer__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .footer__brand {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
  }

  .footer__produced {
    font-family: var(--font-mono);
    font-size: .6rem;
    text-transform: uppercase;
    letter-spacing: .1em;
    color: var(--text-dim);
  }

  .footer__logos {
    display: flex;
    align-items: center;
    gap: .4rem;
  }

  .footer__logo {
    height: 18px;
    width: auto;
    flex-shrink: 0;
  }

  .footer__logo--kntxt {
    opacity: .7;
  }

  .footer__logo--cs {
    filter: brightness(0) invert(1);
    opacity: .7;
    height: 20px;
  }

  .footer__x {
    color: var(--text-dim);
    font-size: .75rem;
    font-weight: 300;
    margin: 0 .15rem;
  }

  .footer__cs-link {
    display: inline-flex;
    align-items: center;
    gap: .35rem;
    color: var(--text-muted);
    text-decoration: none;
    transition: color var(--duration) var(--ease);
  }

  .footer__cs-link:hover {
    color: var(--text);
    opacity: 1;
  }

  .footer__cs-name {
    font-family: var(--font-display);
    font-size: .85rem;
    font-weight: 600;
    letter-spacing: .04em;
  }

  .footer__info {
    font-family: var(--font-mono);
    font-size: .65rem;
    color: var(--text-dim);
    letter-spacing: .04em;
  }

  @media (max-width: 600px) {
    .footer__inner {
      flex-direction: column;
      gap: var(--space-md);
      text-align: center;
    }
    .footer__brand {
      flex-direction: column;
      gap: var(--space-xs);
    }
  }
</style>
